# Configurações Gerais
LANGUAGE="Português" # Idioma das respostas do agente
DEFAULT_PROVIDER="OpenAI" # Provedor padrão (OpenAI, Gemini, OpenRouter, DeepSeek, LM Studio)

# Bot Telegram Config
TELEGRAM_BOT_TOKEN="seu_token_aqui" # Token obtido no @BotFather
TELEGRAM_ALLOWED_USER_IDS="id1,id2" # IDs dos usuários autorizados separados por vírgula

# IA Providers (Ordem de Fallback: LM Studio -> Gemini -> DeepSeek/OpenAI)

# Local: LM Studio
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LM_STUDIO_MODELS="nome_do_modelo_aqui"

# Local: Ollama (Opcional)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODELS="mistral:7b"

# API Keys para Provedores Cloud
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."
DEEPSEEK_API_KEY="sk-..."
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="qwen/qwen3.6-plus:free"

# Agent Core Settings
MAX_ITERATIONS=30 # Limite máximo de iterações por tarefa
MEMORY_WINDOW_SIZE=10 # Quantidade de mensagens mantidas no contexto
LOG_LEVEL="INFO" # Nível de log (DEBUG, INFO, WARNING, ERROR)

# Configurações de Caminho (Opcional - caminhos padrão serão usados se comentados)
DATABASE_PATH="./data/qagent.db"
# SKILLS_DIR="./agents/skills"
# TMP_DIR="./tmp"
