# Bot Telegram Config
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=12345678,98765432

# IA Providers (Ordem de Fallback: LM Studio -> Gemini -> DeepSeek/OpenAI)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODELS=model_name_1,model_name_2
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENAI_API_KEY=your_openai_key_here

# Agent Core Settings
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=10
LOG_LEVEL=INFO

# Os caminhos abaixo são resolvidos dinamicamente, mas podem ser sobrescritos:
# DATABASE_PATH=./data/qagent.db
# SKILLS_DIR=./agents/skills
# TMP_DIR=./tmp
